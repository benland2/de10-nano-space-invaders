	eq[] = eq_node[];
	eq_node[6..0] = eq_wire[6..0];
	eq_wire[] = ( w_anode499w[3..3], w_anode488w[3..3], w_anode477w[3..3], w_anode466w[3..3], w_anode455w[3..3], w_anode444w[3..3], w_anode433w[3..3], w_anode415w[3..3]);
