	w_anode444w[] = ( (w_anode444w[2..2] & (! data_wire[2..2])), (w_anode444w[1..1] & data_wire[1..1]), (w_anode444w[0..0] & (! data_wire[0..0])), B"1");
	w_anode455w[] = ( (w_anode455w[2..2] & (! data_wire[2..2])), (w_anode455w[1..1] & data_wire[1..1]), (w_anode455w[0..0] & data_wire[0..0]), B"1");
	w_anode466w[] = ( (w_anode466w[2..2] & data_wire[2..2]), (w_anode466w[1..1] & (! data_wire[1..1])), (w_anode466w[0..0] & (! data_wire[0..0])), B"1");
